# ==============================================================================
# AMBIENTE E SERVIDOR (Gradio / Python)
# ==============================================================================
# Define o ambiente de execução (development, staging, production)
ENVIRONMENT=development

# Configurações do servidor web Gradio (7860 é a porta padrão)
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# ==============================================================================
# LLM PROVIDERS E APIS EXTERNAS
# ==============================================================================

# OpenAI - Obrigatório para geração de Embeddings e Chat
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-sua_chave_openai_aqui"

# ElevenLabs - Obrigatório para síntese de voz TTS
# Obtenha em: https://elevenlabs.io/
ELEVENLABS_API_KEY="sk_sua_chave_elevenlabs_aqui"

# HuggingFace - Necessário para baixar modelos como o BGE-M3 Reranker sem rate limit
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN="hf_seu_token_huggingface_aqui"
HF_HUB_DISABLE_SYMLINKS_WARNING="1"

# ==============================================================================
# OBSERVABILIDADE E RASTREAMENTO (LANGSMITH)
# ==============================================================================
# Essencial para debug do pipeline LangChain
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="lsv2_sua_chave_langsmith_aqui"
LANGCHAIN_PROJECT="RAG_Meditacoes_Avaliacao"

# ==============================================================================
# CONFIGURAÇÕES DO RAG E BANCO VETORIAL
# ==============================================================================

# Diretório onde o ChromaDB salva os vetores localmente
CHROMA_PERSIST_DIR=data/processed/chroma_db

# Calibração do corte semântico (Percentil de distância)
CHUNKING_THRESHOLD=85

# ==============================================================================
# PREFERÊNCIAS E LOGS
# ==============================================================================
# Nível de detalhamento do terminal (debug, info, warning, error)
LOG_LEVEL=info
# ==============================================================================
# AMBIENTE E SERVIDOR (Gradio / Python)
# ==============================================================================
# Define o ambiente de execução (development, staging, production)
ENVIRONMENT=development

# Configurações do servidor web Gradio (7860 é a porta padrão)
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=127.0.0.1

# ==============================================================================
# LLM PROVIDERS (Configurações de API)
# ==============================================================================

# OpenAI - Obrigatório para geração de Embeddings e Chat
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua_chave_openai_aqui

# Anthropic (Opcional) - Alternativa para o modelo de Chat
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# Google Gemini (Opcional) - Alternativa para o modelo de Chat
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=sua_chave_google_aqui

# ==============================================================================
# CONFIGURAÇÕES DO RAG E BANCO VETORIAL
# ==============================================================================

# Diretório onde o ChromaDB salva os vetores localmente
CHROMA_PERSIST_DIR=data/processed/chroma_db

# Calibração do corte semântico (Percentil de distância)
CHUNKING_THRESHOLD=85

# ==============================================================================
# PREFERÊNCIAS E LOGS
# ==============================================================================
# Nível de detalhamento do terminal (debug, info, warning, error)
LOG_LEVEL=info